// SSL v7.0 - Simplified Kernel Compiler Test
// Tests new lexer tokens (no runtime dependencies)

fn test_lexer() {
    let test_code = "@freestanding fn main() { return 42 }"
    
    print("Testing Lexer Extensions...")
    print("Input: " + test_code)
    print("")
    
    let tokens = lex_simple(test_code)
    print("Tokens: " + tokens)
    
    return 0
}

fn lex_simple(src: String) -> String {
    let mut tokens = ""
    let mut i = 0
    let slen = len(src)
    
    while i < slen {
        let c = char_at(src, i)
        if c == "@" { 
            tokens = tokens + "[AT]"
        } else {
        if c == " " {
            tokens = tokens + " "
        } else {
            tokens = tokens + c
        }}
        i = i + 1
        0
    }
    
    return tokens
}

test_lexer()
